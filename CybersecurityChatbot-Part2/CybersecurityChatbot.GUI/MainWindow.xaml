<Window x:Class="CybersecurityChatbot.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Chatbot"
        Height="680"
        Width="1100"
        MinWidth="980"
        MinHeight="650"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0F172A"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <!-- Styles -->
    <Window.Resources>

        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="52"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Background" Value="#06B6D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0891B2"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0E7490"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}"/>

        <Style x:Key="SecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#1D4ED8"/>
        </Style>

        <Style x:Key="DangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>

        <Style x:Key="RoundedTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

    </Window.Resources>

    <!-- Main Layout -->
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="18"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0"
                Background="#111827"
                CornerRadius="16"
                Padding="18">

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <TextBlock Text="CHATBOT MENU"
                               Foreground="#22D3EE"
                               FontSize="24"
                               FontWeight="Bold"
                               Margin="0,0,0,18"/>

                    <TextBlock Text="Name"
                               Foreground="White"
                               Margin="0,0,0,8"/>

                    <TextBox x:Name="NameInput"
                             Style="{StaticResource RoundedTextBoxStyle}"
                             Text="Bono"/>

                    <Button Content="Set Name"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Margin="0,12,0,20"
                            Click="SetName_Click"/>

                    <TextBlock Text="Quick Topics"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button Content="Password Safety" Style="{StaticResource SidebarButtonStyle}" Click="QuickTopic_Click"/>
                    <Button Content="Phishing" Style="{StaticResource SidebarButtonStyle}" Click="QuickTopic_Click"/>
                    <Button Content="Privacy" Style="{StaticResource SidebarButtonStyle}" Click="QuickTopic_Click"/>
                    <Button Content="Malware" Style="{StaticResource SidebarButtonStyle}" Click="QuickTopic_Click"/>
                    <Button Content="2FA" Style="{StaticResource SidebarButtonStyle}" Margin="0,0,0,20" Click="QuickTopic_Click"/>

                    <TextBlock Text="Tools"
                               Foreground="White"
                               FontWeight="Bold"
                               Margin="0,0,0,10"/>

                    <Button Content="Show Memory"
                            Style="{StaticResource SecondaryActionButtonStyle}"
                            Click="ShowMemory_Click"/>

                    <Button Content="Clear Chat"
                            Style="{StaticResource DangerActionButtonStyle}"
                            Margin="0,0,0,20"
                            Click="ClearChat_Click"/>

                    <!-- Hints -->
                    <Border Background="#1E293B"
                            CornerRadius="12"
                            Padding="14">
                        <StackPanel>
                            <TextBlock Text="Hints"
                                       Foreground="#67E8F9"
                                       FontWeight="Bold"/>
                            <TextBlock Text="‚ÄĘ I'm worried about scams" Foreground="White"/>
                            <TextBlock Text="‚ÄĘ Tell me more" Foreground="White"/>
                            <TextBlock Text="‚ÄĘ Why is it dangerous?" Foreground="White"/>
                            <TextBlock Text="‚ÄĘ I'm interested in privacy" Foreground="White"/>
                            <TextBlock Text="‚ÄĘ What do you remember?" Foreground="White"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="#111827"
                    CornerRadius="16"
                    Padding="18"
                    MouseLeftButtonDown="HeaderBorder_MouseLeftButtonDown">
                <StackPanel>
                    <TextBlock Text="CYBERSECURITY AWARENESS CHATBOT"
                               Foreground="#22D3EE"
                               FontSize="28"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="South Africa Edition"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <!-- ASCII -->
            <Border Grid.Row="2"
                    Background="#1E293B"
                    CornerRadius="16"
                    Padding="18">
                <StackPanel>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text=" ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó "/>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text="‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó"/>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text="‚Ėą‚Ėą‚ēĎ      ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ"/>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text="‚Ėą‚Ėą‚ēĎ       ‚ēö‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēĚ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó"/>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text="‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ"/>
                    <TextBlock FontFamily="Consolas" Foreground="#67E8F9" TextAlignment="Center"
                               Text=" ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ   ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ"/>
                </StackPanel>
            </Border>

            <!-- Chat -->
            <Border Grid.Row="4"
                    Background="#111827"
                    CornerRadius="16"
                    Padding="16">
                <ScrollViewer x:Name="ChatScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ChatPanel"/>
                </ScrollViewer>
            </Border>

            <!-- Input -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <TextBox x:Name="UserInput"
                         Grid.Column="0"
                         Style="{StaticResource RoundedTextBoxStyle}"
                         KeyDown="UserInput_KeyDown"/>

                <Button Grid.Column="2"
                        Content="Send"
                        Height="44"
                        Background="#06B6D4"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        Click="Send_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>